# Upstash Redis (required for online multiplayer state)
# Install from Vercel Marketplace: https://vercel.com/marketplace/upstash
# Redis.fromEnv() reads UPSTASH_REDIS_REST_URL and UPSTASH_REDIS_REST_TOKEN
# Fallback: in-memory Map if these are not set (volatile, dev only)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
